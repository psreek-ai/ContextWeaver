# ContextWeaver Environment Configuration
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key (get one at https://console.anthropic.com)
CW_ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub Integration (optional but recommended) ─────────────────────────────

# GitHub Personal Access Token with `repo` scope
# Required for: contextweaver mine github
CW_GITHUB_TOKEN=github_pat_...

# Default repository to analyze (owner/repo format)
CW_GITHUB_REPO=your-org/your-repo

# ── Storage ───────────────────────────────────────────────────────────────────

# Directory for ChromaDB vector store persistence
CW_CHROMA_PERSIST_DIR=.contextweaver/chroma

# Path for the decision knowledge graph
CW_GRAPH_PERSIST_PATH=.contextweaver/decision_graph.json

# ── API Server ────────────────────────────────────────────────────────────────

CW_API_HOST=0.0.0.0
CW_API_PORT=8765

# Set a strong secret for production deployments
# Clients must send: Authorization: Bearer <this value>
CW_API_SECRET=dev-secret-change-me

# ── Agent Behavior ────────────────────────────────────────────────────────────

# Claude model to use (claude-opus-4-6 for best archaeology quality)
CW_CLAUDE_MODEL=claude-opus-4-6

# Days of history to mine on first run (365 = 1 year)
CW_MINING_LOOKBACK_DAYS=365

# Cosine similarity threshold for conflict detection (0.78 = balanced)
CW_CONFLICT_THRESHOLD=0.78
